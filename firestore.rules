rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Candidates are readable by any authenticated user, but not writable
    match /candidates/{candidateId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only admin can update
    }

    // Phases are readable by any authenticated user, but not writable
    match /election_phases/{phaseId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Votes logic
    match /votes/{voteId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() 
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.keys().hasAll(['candidateId', 'timestamp']);
      allow update, delete: if false; // Votes cannot be modified
    }
  }
}
